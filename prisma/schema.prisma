generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  HOST
  ADMIN
}

enum SignupContactType {
  EMAIL
  PHONE
}

enum HostIdDocumentType {
  AADHAAR
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
}

enum VerificationStatus {
  DRAFT
  SUBMITTED
  PENDING
  VERIFIED
  MANUAL_REVIEW
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  RAZORPAY
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(USER)
  /** Loyalty balance (display points); adjust via your rewards rules. */
  loyaltyPoints Int       @default(0)
  passwordHash  String?
  phone         String?   @unique
  phoneVerified DateTime?
  /** Signup channel used to lock verified identifiers (email vs phone). */
  registrationContactType SignupContactType?
  /** One-time profile edit OTP + token (after OTP verify) for sensitive profile updates. */
  profileEditOtpHash          String?
  profileEditOtpExpiresAt     DateTime?
  profileEditOtpLockedUntil   DateTime?
  profileEditOtpAttempts      Int       @default(0)
  profileEditOtpLastSentAt    DateTime?
  profileEditOtpChannel       SignupContactType?
  profileEditTokenHash        String?
  profileEditTokenExpiresAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  hotels        Hotel[]   @relation("OwnerHotels")
  bookings      Booking[]
  reviews       Review[]
  wishlist      WishlistItem[]
  profile       UserProfile?
  hostKyc       HostKycSubmission?
  hostSettings  HostSettings?

  @@index([role])
  @@index([deletedAt])
}

model HostSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business profile
  businessName   String?
  businessEmail  String?
  businessPhone  String?
  businessAddress String?
  taxId          String?

  // Payout / bank
  accountHolderName String?
  bankName          String?
  accountNumberLast4 String?
  ifsc              String?
  swift             String?
  payoutStatus      VerificationStatus @default(DRAFT)

  // Compliance summary (high-level)
  complianceStatus  VerificationStatus @default(DRAFT)
  complianceNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SignupSession {
  id              String            @id @default(cuid())
  role            Role
  contactType     SignupContactType
  email           String?
  phone           String?
  legalName       String
  passwordHash    String

  /** Hash of the one-time signup token returned to client after OTP verification */
  clientTokenHash String            @unique

  otpHash         String
  otpExpiresAt    DateTime
  otpAttempts     Int               @default(0)
  otpLockedUntil  DateTime?
  otpLastSentAt   DateTime?
  verifiedAt      DateTime?
  consumedAt      DateTime?

  ipAddress       String?
  userAgent       String?
  deviceFingerprint String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([role])
  @@index([contactType, email])
  @@index([contactType, phone])
  @@index([verifiedAt])
  @@index([consumedAt])
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  age       Int?
  dob       DateTime?
  businessPhone String?
  businessEmail String?
  address1  String?
  address2  String?
  city      String?
  state     String?
  postalCode String?
  country   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HostKycSubmission {
  id              String             @id @default(cuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  status          VerificationStatus @default(DRAFT)
  documentType    HostIdDocumentType?
  documentFrontUrl String?
  documentBackUrl  String?
  selfieUrl       String?
  reviewReason    String?
  submittedAt     DateTime?
  verifiedAt      DateTime?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

// NextAuth (OAuth + optional database sessions)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Hotel {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation("OwnerHotels", fields: [ownerId], references: [id])
  name        String
  slug        String   @unique
  /** Human-readable location string shown on hotel details page */
  location    String?
  city        String
  country     String
  address     String?
  stars       Int      @default(0)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  reviewLabel String   @default("New")
  /** Base price in USD for display (nightly) */
  priceUsd    Float    @default(0)
  /** Primary hero image URL */
  image       String?
  description String?
  coverImage  String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms       Room[]
  gallery     HotelImage[]
  amenities   HotelAmenity[]
  perks       HotelPerk[]
  reviews     Review[]
  bookings    Booking[]
  wishlistItems WishlistItem[]

  @@index([city, stars])
  @@index([ownerId])
  @@index([slug])
  @@index([deletedAt])
}

model HotelImage {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([hotelId, sortOrder])
}

model HotelAmenity {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name    String

  @@index([hotelId])
  @@unique([hotelId, name])
}

model HotelPerk {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name    String

  @@index([hotelId])
  @@unique([hotelId, name])
}

model Room {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  name          String
  sleeps        Int      @default(2)
  bed           String   @default("Double")
  refundable    Boolean  @default(false)
  /** Stored numeric amount in Indian Rupees (legacy column name `priceUsd` in DB). */
  priceUsd      Float    @default(0)
  /** Room-specific perks as JSON string array, e.g. ["Breakfast","Late checkout"]. */
  perks         Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings      Booking[]

  @@index([hotelId, isActive])
}

model Booking {
  id          String        @id @default(cuid())
  bookingRef  String        @unique
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  hotelId     String
  hotel       Hotel         @relation(fields: [hotelId], references: [id])
  roomId      String
  room        Room          @relation(fields: [roomId], references: [id])
  status      BookingStatus @default(PENDING)
  startTime   DateTime
  endTime     DateTime
  slotHours   Int
  finalAmount Int
  currency    String        @default("INR")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment     Payment?

  @@index([roomId, startTime, endTime])
  @@index([userId, status])
  @@index([hotelId, status])
  @@index([status, startTime])
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id])
  status      PaymentStatus @default(PENDING)
  method      PaymentMethod?
  providerRef String?
  amount      Int
  currency    String        @default("INR")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  hotelId    String
  hotel      Hotel    @relation(fields: [hotelId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  rating     Int
  comment    String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hotelId, isApproved])
  @@index([userId])
}

model WishlistItem {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, hotelId])
  @@index([userId])
}

